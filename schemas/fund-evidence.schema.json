{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "stock-analysis Fund Evidence Pack",
  "type": "object",
  "required": ["schema_version", "asset_type", "symbol", "trade_date", "modules", "_meta"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "asset_type": {"const": "fund"},
    "symbol": {"type": "string"},
    "trade_date": {"type": "string", "pattern": "^[0-9]{8}$"},
    "modules": {"type": "object", "required": ["F1", "F2", "F3", "F4", "F5", "F6", "F7", "F8"]},
    "_meta": {"type": "object", "required": ["coverage", "available_modules", "missing_modules", "source_events"]}
  }
}
